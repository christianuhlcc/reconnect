# ── LiveKit (self-hosted on AWS Frankfurt eu-central-1) ─────────────────────
# Point both vars at your self-hosted instance.
# For dev, keep pointing at LiveKit Cloud (reconnect-sxwx2np5.livekit.cloud).
LIVEKIT_URL=wss://livekit.yourdomain.com
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.yourdomain.com

# Server-side only — never expose these
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ── Optional: room access secret ────────────────────────────────────────────
# If set, /api/token requires ?s=<value> matching this secret.
# Share the full room link (including ?s=) with your team.
# Must be set on BOTH server and client (NEXT_PUBLIC_) so the client appends it.
LIVEKIT_ROOM_SECRET=change-me-to-a-random-string
NEXT_PUBLIC_ROOM_SECRET=change-me-to-a-random-string
